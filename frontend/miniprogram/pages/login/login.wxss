.login-container {
  padding: 60rpx 40rpx;
}

.login-form {
  background: #fff;
  padding: 40rpx;
  border-radius: 16rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 30rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.btn-primary {
  background-color: #409eff;
  color: #fff;
  margin-top: 40rpx;
}

.btn-wechat {
  background-color: #07c160;
  color: #fff;
  margin-top: 20rpx;
}
